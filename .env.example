# Razorpay credentials (never commit real values — copy to .env locally, set in Vercel Dashboard for production)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Plan IDs — create Plans in Razorpay Dashboard (test mode first), paste plan_... IDs here
RAZORPAY_PLAN_SPONSOR_MONTHLY_INR=plan_
RAZORPAY_PLAN_SPONSOR_ANNUAL_INR=plan_
RAZORPAY_PLAN_SPONSOR_MONTHLY_USD=plan_
RAZORPAY_PLAN_SPONSOR_ANNUAL_USD=plan_
RAZORPAY_PLAN_SINGULARITY_MONTHLY_INR=plan_
RAZORPAY_PLAN_SINGULARITY_ANNUAL_INR=plan_
RAZORPAY_PLAN_SINGULARITY_MONTHLY_USD=plan_
RAZORPAY_PLAN_SINGULARITY_ANNUAL_USD=plan_

# Display labels shown on pricing cards (optional — sensible defaults used if unset)
# RAZORPAY_DISPLAY_SPONSOR_MONTHLY_INR=₹199/mo
# RAZORPAY_DISPLAY_SPONSOR_ANNUAL_INR=₹1,990/yr
# RAZORPAY_DISPLAY_SPONSOR_MONTHLY_USD=$2/mo
# RAZORPAY_DISPLAY_SPONSOR_ANNUAL_USD=$20/yr
# RAZORPAY_DISPLAY_SINGULARITY_MONTHLY_INR=₹899/mo
# RAZORPAY_DISPLAY_SINGULARITY_ANNUAL_INR=₹8,990/yr
# RAZORPAY_DISPLAY_SINGULARITY_MONTHLY_USD=$9/mo
# RAZORPAY_DISPLAY_SINGULARITY_ANNUAL_USD=$90/yr
