# Whitelist-style ignore: exclude everything, then re-include only what the
# extension needs at runtime. New root files are excluded by default —
# published VSIXs <=2.3.1 leaked .env under the old blacklist approach.
**
.*
.*/**
**/.*

# Bundled extension + renderer output (top-level JS only; maps/subdirs stay out)
!dist/*.js

# Webview templates (free set; package-pro merges pro templates in temporarily)
!templates/**

# Icons, walkthrough media, marketplace metadata
!resources/**
!walkthroughs/**
!README.md
!CHANGELOG.md
!LICENSE
!package.json

# Runtime dependencies kept external to the esbuild bundle
!node_modules/pg/**
!node_modules/pg-types/**
!node_modules/pg-protocol/**
!node_modules/pg-int8/**
!node_modules/pg-pool/**
!node_modules/pg-connection-string/**
!node_modules/pgpass/**
!node_modules/packet-reader/**
!node_modules/postgres-array/**
!node_modules/postgres-bytea/**
!node_modules/postgres-date/**
!node_modules/postgres-interval/**
!node_modules/postgres-range/**
!node_modules/split2/**
!node_modules/xtend/**
!node_modules/ssh2/**
!node_modules/asn1/**
!node_modules/bcrypt-pbkdf/**
!node_modules/cpu-features/**
!node_modules/nan/**
!node_modules/tweetnacl/**
!node_modules/safer-buffer/**
!node_modules/vscode-languageclient/**
!node_modules/vscode-languageserver/**
