{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@features/*": ["features/*"],
      "@core/*": ["core/*"],
      "@ui/*": ["ui/*"]
    },
    "jsx": "react",
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": [
      "node",
      "vscode",
      "pg"
    ],
    "esModuleInterop": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "src/test/unit/**",
    "src/test/integration/**",
    "src/test/runTest.ts",
    "src/test/setup.ts",
    "src/test/testUtils.ts"
  ]
}